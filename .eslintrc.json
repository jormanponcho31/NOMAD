{
  "root": true,
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "ignorePatterns": [
    "**/*.ts",
    "**/*.tsx",
    "node_modules/**",
    "dist/**",
    ".expo/**",
    "web-build/**"
  ]
}
